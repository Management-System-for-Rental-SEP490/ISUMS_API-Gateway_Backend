<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="unknown-service"/>
    <springProperty scope="context" name="environment" source="isums.observability.environment" defaultValue="dev"/>
    <springProperty scope="context" name="region" source="isums.observability.region" defaultValue="local"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.JsonEncoder">
            <withTimestamp>true</withTimestamp>
            <withLevel>true</withLevel>
            <withThreadName>true</withThreadName>
            <withLoggerName>true</withLoggerName>
            <withContext>true</withContext>
            <withMDC>true</withMDC>
            <withMessage>true</withMessage>
            <withFormattedMessage>true</withFormattedMessage>
            <withThrowable>true</withThrowable>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_FILE:-E:/ISUMS/logs/api-gateway.log}</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL_ROOT:-INFO}">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>